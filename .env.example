# === Database ===
POSTGRES_USER=vibecrush
POSTGRES_PASSWORD=          # REQUIRED — generate with: openssl rand -base64 32
POSTGRES_DB=vibecrush
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}

# === Redis ===
REDIS_PASSWORD=             # REQUIRED — generate with: openssl rand -base64 32
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379/0

# === JWT ===
JWT_SECRET=                 # REQUIRED — min 32 chars, generate with: openssl rand -base64 48

# === S3 / MinIO ===
MINIO_ROOT_USER=            # REQUIRED
MINIO_ROOT_PASSWORD=        # REQUIRED — min 8 chars
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=              # REQUIRED — same as MINIO_ROOT_USER
S3_SECRET_KEY=              # REQUIRED — same as MINIO_ROOT_PASSWORD
S3_BUCKET=vibecrush

# === Stripe ===
STRIPE_SECRET_KEY=          # REQUIRED for payments
STRIPE_WEBHOOK_SECRET=      # REQUIRED for webhook verification

# === CORS ===
ALLOWED_ORIGINS=http://localhost:3000
