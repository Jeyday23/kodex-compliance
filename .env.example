# === DATABASE ===
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/vibecrush

# === REDIS ===
REDIS_URL=redis://localhost:6379/0

# === JWT (generate with: python -c "import secrets; print(secrets.token_urlsafe(64))") ===
JWT_SECRET=REPLACE_ME_WITH_64_CHAR_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=10080

# === S3 / MINIO ===
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=REPLACE_ME
S3_SECRET_KEY=REPLACE_ME
S3_BUCKET=vibecrush-videos
S3_REGION=us-east-1

# === STRIPE ===
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# === CORS (comma-separated origins) ===
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# === VIDEO ===
MAX_VIDEO_DURATION_SECONDS=30
MAX_VIDEO_SIZE_MB=50

# === DEV ONLY — set to false in production ===
OTP_BYPASS_ENABLED=true
